#!/bin/bash

# This script copies from _template into each exercise subdir, translating
# certain placeholder strings in the process.

TEMPLATE_DIR="exercises/_template"

# Find all the files in the template directory, relative to it.
TEMPLATE_FILES=$(find "$TEMPLATE_DIR" -type f | sed "s|^$TEMPLATE_DIR/||")

EXERCISE_DIRS=(
  "introduction_to_tdd"
  "inside_out_tdd"
)

wait_for_output() {
  local cmd="$1"
  local needle="$2"
  local timeout="$3"

  local log
  log=$(mktemp)

  # Start command, redirect output to a file
  bash -c "$cmd" >"$log" 2>&1 &
  local pid=$!

  cleanup() {
    if [[ -n "${pid:-}" ]]; then
      kill -TERM "$pid" 2>/dev/null || true
      wait "$pid" 2>/dev/null || true
    fi
    if [[ -n "${tail_pid:-}" ]]; then
      kill "$tail_pid" 2>/dev/null || true
      wait "$tail_pid" 2>/dev/null || true
    fi
    rm -f "$log"
  }

  # Stream output in background
  tail -f "$log" &
  local tail_pid=$!

  # Ensure both the main process and tail are cleaned up on exit
  trap cleanup RETURN

  # Poll for the string
  for ((i=0; i<timeout*10; i++)); do
    if grep -Fq "$needle" "$log"; then
      return 0
    fi

    # Optional: fail fast if process died
    if ! kill -0 "$pid" 2>/dev/null; then
      echo "Process exited before producing expected output" >&2
      return 1
    fi

    sleep 0.1
  done

  echo "Timeout waiting for: $needle" >&2
  return 1
}

for EXERCISE_DIR in "${EXERCISE_DIRS[@]}"; do
  echo "Processing exercise: $EXERCISE_DIR"
  for TEMPLATE_FILE in $TEMPLATE_FILES; do
    echo "  Templating file: $TEMPLATE_FILE"
    SRC_FILE="$TEMPLATE_DIR/$TEMPLATE_FILE"
    DST_FILE="exercises/$EXERCISE_DIR/$TEMPLATE_FILE"

    # Create the destination directory if it doesn't exist.
    mkdir -p "$(dirname "$DST_FILE")" || {
      echo "Failed to create directory for $DST_FILE"
      exit 1
    }

    # Copy the file, translating placeholder strings.
    sed "s|<EXERCISE_DIR>|$EXERCISE_DIR|g" "$SRC_FILE" > "$DST_FILE" || {
      echo "Failed to process $TEMPLATE_FILE for $EXERCISE_DIR"
      exit 1
    }
  done

  echo "Running checks for $EXERCISE_DIR"
  # Run the check script for the exercise.
  docker compose -f "exercises/$EXERCISE_DIR/docker-compose.yml" run --rm exercises ./scripts/check || {
    echo "Checks failed for $EXERCISE_DIR"
    exit 1
  }

  # Run the continuous test runner for the exercise.
  echo "Testing continuous test runner for $EXERCISE_DIR"
  wait_for_output "docker compose -f exercises/$EXERCISE_DIR/docker-compose.yml run --rm tests" "Waiting for changes" 30 || {
    echo "Continuous test runner failed to start for $EXERCISE_DIR"
    exit 1
  }

  echo "Checks passed for $EXERCISE_DIR"
done
