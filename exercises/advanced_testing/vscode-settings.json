      "name": "ANTHROPIC_DEFAULT_HAIKU_MODEL",
      "value": "eu.anthropic.claude-haiku-4-5-20251001-v1:0"
    },
    {
      "name": "BEDROCK_MODEL",
      "value": "eu.anthropic.claude-sonnet-4-5-20250929-v1:0"
    },
    {
      "name": "ANTHROPIC_BEDROCK_BASE_URL",
